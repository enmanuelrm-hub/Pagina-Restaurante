generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String?
  role      String   @default("WAITER")
  createdAt DateTime @default(now())
  orders    Order[]  @relation("WaiterOrders")
  deliveries Delivery[]
}

model Table {
  id        Int      @id @default(autoincrement())
  label     String
  seats     Int
  status    String   @default("FREE")
  orders    Order[]
}

model MenuItem {
  id          Int           @id @default(autoincrement())
  name        String
  description String
  price       Float
  category    String
  orderItems  OrderItem[]
  inventory   InventoryItem?
}

model InventoryItem {
  id               Int      @id @default(autoincrement())
  name             String
  quantity         Float
  unit             String
  lowStockThreshold Float   @default(10.0)
  menuItem         MenuItem? @relation(fields: [menuItemId], references: [id])
  menuItemId       Int?     @unique
}

model Order {
  id           Int         @id @default(autoincrement())
  createdAt    DateTime    @default(now())
  status       String      @default("PENDING")
  note         String?
  type         String      @default("DINE_IN")
  table        Table?      @relation(fields: [tableId], references: [id])
  tableId      Int?
  delivery     Delivery?   @relation(fields: [deliveryId], references: [id])
  deliveryId   Int?        @unique
  orderItems   OrderItem[]
  total        Float       @default(0.0)
  waiter       User?       @relation("WaiterOrders", fields: [waiterId], references: [id])
  waiterId     String?
}

model OrderItem {
  id          Int    @id @default(autoincrement())
  quantity    Int    @default(1)
  specialNote String?
  menuItem    MenuItem @relation(fields: [menuItemId], references: [id])
  menuItemId  Int
  order       Order    @relation(fields: [orderId], references: [id])
  orderId     Int
}

model Delivery {
  id           Int            @id @default(autoincrement())
  address      String
  status       String         @default("ASSIGNED")
  courier      User?          @relation(fields: [courierId], references: [id])
  courierId    String?
  estimatedAt  DateTime?
  order        Order?
  orderId      Int?           @unique
}
